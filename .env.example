# Value Proposition: Centralized, type-safe configuration for enterprise MySQL MCP deployment.
# Note: server-config-example.json is for server config, while mcp-config-example.json is for client config.

# Database
# Note: overridden to 'mysql' when running via docker-compose
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=mcp_user
MYSQL_PASSWORD=secure_password
MYSQL_DATABASE=testdb
# Connection Pool
MYSQL_POOL_SIZE=10 # Maps to `pool.connectionLimit` in server-config-example.json

# Tool Filtering (e.g., starter, essential, dev-power, ai-data-nosql, ai-spatial, dba-monitor, dba-manage, dba-secure, base-relational, base-nosql, ecosystem)
TOOL_FILTER=starter

# Server
MYSQLMCP_PORT=3000
MCP_HOST=127.0.0.1
MCP_ENABLE_HSTS=false
TRUST_PROXY=false
MCP_METRICS_EXPORT=false
ALLOWED_IO_ROOTS=/app/data,C:/temp/mcp-sandbox,/tmp/mcp-sandbox
MCP_AUTH_TOKEN=your-secure-auth-token
AUDIT_LOG_PATH=/app/data/audit.jsonl
METADATA_CACHE_TTL_MS=30000
CODE_MODE_MAX_RESULT_SIZE=102400
MCP_REQUEST_TIMEOUT=30000
MCP_HEADERS_TIMEOUT=5000
REDIS_URL=redis://localhost:6379

# OAuth
OAUTH_ENABLED=false
OAUTH_ISSUER=https://auth.example.com
OAUTH_AUDIENCE=mysql-mcp-client
OAUTH_JWKS_URI=
OAUTH_CLOCK_TOLERANCE=60

# Advanced & Ecosystem
MYSQL_ROUTER_URL=https://localhost:8443
MYSQL_ROUTER_USER=rest_api
MYSQL_ROUTER_PASSWORD=password
MYSQL_ROUTER_INSECURE=true
PROXYSQL_HOST=localhost
PROXYSQL_PORT=6032
PROXYSQL_USER=radmin
PROXYSQL_PASSWORD=radmin
MYSQLSH_PATH=mysqlsh
MYSQL_XPORT=33060
CODEMODE_ISOLATION=sandbox
LOG_LEVEL=info
