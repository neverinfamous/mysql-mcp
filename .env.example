# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=your_database
# Connection Pool
MYSQL_POOL_SIZE=10
MYSQL_POOL_TIMEOUT=10000
MYSQL_POOL_QUEUE_LIMIT=0

# GitHub
# GITHUB_TOKEN=

# Tool Filtering
MYSQL_MCP_TOOL_FILTER=starter

# Server
# MySQL Router REST API (optional)
MYSQL_ROUTER_URL=https://localhost:8443
MYSQL_ROUTER_USER=rest_api
MYSQL_ROUTER_PASSWORD=your_router_password
# MYSQL_ROUTER_API_VERSION=v2
MYSQL_ROUTER_INSECURE=true
# ProxySQL Admin Interface (optional)
PROXYSQL_HOST=localhost
PROXYSQL_PORT=6032
PROXYSQL_USER=radmin
PROXYSQL_PASSWORD=radmin
# MySQL Shell (optional)
MYSQLSH_PATH=C:\Program Files\MySQL\MySQL Shell 9.5\bin\mysqlsh.exe
# MYSQLSH_TIMEOUT=30000
# MYSQL_XPORT=33060
MYSQLMCP_PORT=3001
MCP_HOST=localhost
LOG_LEVEL=info
# MCP_AUTH_TOKEN=your_secure_token
# REDIS_URL=redis://localhost:6379
# ALLOWED_IO_ROOTS=C:/temp,/tmp
# MCP_ENABLE_HSTS=true
# TRUST_PROXY=true
# MCP_METRICS_EXPORT=true
CODEMODE_ISOLATION=isolate
# CODE_MODE_MAX_RESULT_SIZE=102400
# Cache TTL for schema metadata in milliseconds
METADATA_CACHE_TTL_MS=30000
# Audit Logging (Optional)
# AUDIT_LOG_PATH=./audit.jsonl
# AUDIT_LOG_MAX_SIZE=10485760
# AUDIT_REDACT=true
# AUDIT_READS=false
# AUDIT_BACKUP=true
# AUDIT_BACKUP_DATA=false
# AUDIT_BACKUP_MAX_SIZE=52428800

# OAuth
OAUTH_ENABLED=false
OAUTH_ISSUER=http://localhost:8080/realms/mysql-mcp
OAUTH_AUDIENCE=mysql-mcp
# OAUTH_JWKS_URI=                # Optional: auto-discovered from issuer
# OAUTH_CLOCK_TOLERANCE=60       # Optional: clock drift tolerance in seconds

# Skill Injection
# MYSQL_SKILL_PATH=C:\Users\chris\Desktop\adamic\skills\mysql\SKILL.md
