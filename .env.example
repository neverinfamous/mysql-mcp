# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=testdb
# Connection Pool
MYSQL_POOL_SIZE=20

# Tool Filtering (e.g., starter, essential, dev-power, ai-data-nosql, ai-spatial, dba-monitor, dba-manage, dba-secure, base-relational, base-nosql, codemode, ecosystem, router, -core)
TOOL_FILTER=starter



# Server
MYSQLMCP_PORT=3000
MCP_HOST=localhost
MCP_ENABLE_HSTS=true
TRUST_PROXY=true
MCP_METRICS_EXPORT=true
ALLOWED_IO_ROOTS=C:/temp,/tmp
MCP_AUTH_TOKEN=
METADATA_CACHE_TTL_MS=30000
CODE_MODE_MAX_RESULT_SIZE=102400


# OAuth
OAUTH_ENABLED=false
OAUTH_ISSUER=http://localhost:8080/realms/mysql-mcp
OAUTH_AUDIENCE=mysql-mcp
OAUTH_JWKS_URI=
OAUTH_CLOCK_TOLERANCE=60

# Advanced & Ecosystem
MYSQL_ROUTER_URL=https://localhost:8443
MYSQL_ROUTER_USER=rest_api
MYSQL_ROUTER_PASSWORD=password
MYSQL_ROUTER_INSECURE=true
PROXYSQL_HOST=localhost
PROXYSQL_PORT=6032
PROXYSQL_USER=radmin
PROXYSQL_PASSWORD=radmin
MYSQLSH_PATH=
MYSQL_XPORT=33060
CODEMODE_ISOLATION=
LOG_LEVEL=info
