{
  "mcpServers": {
    "user-mysql": {
      "command": "node",
      "args": [
        "/absolute/path/to/mysql-mcp/dist/cli.js",
        "--allowed-io-roots",
        "C:/temp,/tmp"
      ],
      "env": {
        "MYSQL_HOST": "localhost",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "root",
        "MYSQL_PASSWORD": "password",
        "MYSQL_DATABASE": "testdb",
        "MYSQL_POOL_SIZE": "10",
        "MYSQL_POOL_TIMEOUT": "10000",
        "MYSQL_POOL_QUEUE_LIMIT": "0",
        "OAUTH_ENABLED": "false",
        "LOG_LEVEL": "info",
        "MCP_ENABLE_HSTS": "true",
        "TRUST_PROXY": "true",
        "MCP_METRICS_EXPORT": "true",
        "MYSQL_MCP_TOOL_FILTER": "starter"
      }
    }
  }
}
