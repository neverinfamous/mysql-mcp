{
  "mcpServers": {
    "user-mysql": {
      "command": "node",
      "args": ["/absolute/path/to/mysql-mcp/dist/cli.js"],
      "env": {
        "MYSQL_HOST": "localhost",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "root",
        "MYSQL_PASSWORD": "password",
        "MYSQL_DATABASE": "testdb",
        "MYSQL_POOL_SIZE": "10",
        "OAUTH_ENABLED": "false",
        "LOG_LEVEL": "info",
        "ALLOWED_IO_ROOTS": "C:/temp,/tmp",
        "MYSQL_MCP_TOOL_FILTER": "starter",
        "METADATA_CACHE_TTL_MS": "30000",
        "CODEMODE_ISOLATION": "worker",
        "CODE_MODE_MAX_RESULT_SIZE": "102400"
      }
    }
  }
}
