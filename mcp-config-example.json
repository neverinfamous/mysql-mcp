{
  "mcpServers": {
    "user-mysql": {
      "command": "node",
      "args": [
        "/absolute/path/to/mysql-mcp/dist/cli.js",
        "--allowed-io-roots",
        "C:/temp,/tmp"
      ],
      "env": {
        "MYSQL_HOST": "localhost",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "root",
        "MYSQL_PASSWORD": "password",
        "MYSQL_DATABASE": "testdb",
        "MYSQL_POOL_SIZE": "10",
        "MYSQL_POOL_TIMEOUT": "10000",
        "MYSQL_POOL_QUEUE_LIMIT": "0",
        "OAUTH_ENABLED": "false",
        "OAUTH_ISSUER": "http://localhost:8080/realms/mysql-mcp",
        "OAUTH_AUDIENCE": "mysql-mcp",
        "OAUTH_JWKS_URI": "",
        "OAUTH_CLOCK_TOLERANCE": "60",
        "LOG_LEVEL": "info",
        "MCP_ENABLE_HSTS": "true",
        "TRUST_PROXY": "true",
        "MCP_METRICS_EXPORT": "true",
        "MYSQL_MCP_TOOL_FILTER": "starter,codemode",
        "MCP_SERVER_NAME": "mysql-mcp",
        "MCP_AUTH_TOKEN": "",
        "ALLOWED_IO_ROOTS": "C:/temp,/tmp",
        "AUDIT_LOG_PATH": "./audit.jsonl",
        "AUDIT_REDACT": "true",
        "AUDIT_READS": "false",
        "AUDIT_LOG_MAX_SIZE": "10485760",
        "AUDIT_BACKUP": "true",
        "AUDIT_BACKUP_DATA": "false",
        "AUDIT_BACKUP_MAX_SIZE": "52428800"
      }
    }
  }
}
