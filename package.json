{
  "name": "@neverinfamous/mysql-mcp",
  "version": "3.2.2",
  "description": "Enterprise-grade MySQL MCP Server with OAuth 2.0 authentication, connection pooling & tool filtering",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mysql-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:types",
    "build:js": "tsup",
    "build:types": "tsc --project tsconfig.build.json --emitDeclarationOnly",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage && pnpm exec tsx scripts/update-badges.ts",
    "test:e2e": "playwright test && pnpm exec tsx scripts/update-badges.ts",
    "test:zod": "node scripts/test-zod-errors.mjs",
    "check": "pnpm run lint && pnpm run typecheck",
    "clean": "rimraf dist",
    "generate:instructions": "node scripts/generate-server-instructions.ts",
    "bench": "vitest bench --run",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "mcp",
    "mysql",
    "database",
    "model-context-protocol",
    "ai",
    "llm",
    "claude",
    "cursor",
    "oauth",
    "typescript"
  ],
  "author": "Adamic.tech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neverinfamous/mysql-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/neverinfamous/mysql-mcp/issues"
  },
  "homepage": "https://github.com/neverinfamous/mysql-mcp#readme",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "jose": "^6.2.3",
    "mysql2": "^3.22.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": {
      "ajv": "8.18.0"
    }
  }
}
